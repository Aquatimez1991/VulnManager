{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VulnManager",
  "version": "0.1.0",
  "identifier": "com.soc.vulnmanager",
  "build": {
    "frontendDist": "../FRONT/dist/web-app/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start --prefix FRONT",
    "beforeBuildCommand": "npm run build --prefix FRONT"
  },
  "app": {
    "windows": [
      {
        "title": "Gestor de Vulnerabilidades SOC",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
